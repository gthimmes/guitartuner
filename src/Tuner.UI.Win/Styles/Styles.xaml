<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:Tuner.UI.Win.Controls"
                    xmlns:converters="clr-namespace:Tuner.UI.Win.Converters">

    <!-- Converters -->
    <converters:DivideByTwoConverter x:Key="DivideByTwoConverter"/>

    <!-- Title Style -->
    <Style x:Key="TitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontWeight" Value="Light"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <!-- String Name Style (Large) -->
    <Style x:Key="StringNameStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="72"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <!-- Frequency Style -->
    <Style x:Key="FrequencyStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
    </Style>

    <!-- Detected Note Style -->
    <Style x:Key="DetectedNoteStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="36"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <!-- Cents Style -->
    <Style x:Key="CentsStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
    </Style>

    <!-- ComboBox Style - Light background with black bold text -->
    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="BorderBrush" Value="#666666"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="Height" Value="32"/>
    </Style>

    <!-- String Button Style -->
    <Style x:Key="StringButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="MinWidth" Value="50"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource AccentBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Signal Level Progress Bar Style -->
    <Style x:Key="SignalLevelStyle" TargetType="ProgressBar">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <Grid>
                            <Rectangle x:Name="PART_Track"/>
                            <Rectangle x:Name="PART_Indicator"
                                       HorizontalAlignment="Left"
                                       Fill="{TemplateBinding Foreground}"
                                       RadiusX="3"
                                       RadiusY="3"/>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Tuner Indicator Style -->
    <Style TargetType="controls:TunerIndicator">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:TunerIndicator">
                    <Border Background="Transparent"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0">
                        <Grid>
                            <!-- Scale marks -->
                            <Canvas x:Name="PART_Canvas">
                                <!-- Center line -->
                                <Rectangle x:Name="PART_CenterLine"
                                           Width="2"
                                           Height="60"
                                           Fill="{StaticResource InTuneBrush}"
                                           Canvas.Left="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource DivideByTwoConverter}}"
                                           Canvas.Top="20"/>

                                <!-- Scale background -->
                                <Rectangle Width="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                           Height="40"
                                           Fill="{StaticResource SurfaceBrush}"
                                           RadiusX="20"
                                           RadiusY="20"
                                           Canvas.Top="30"/>

                                <!-- Flat indicator arrow -->
                                <Path x:Name="PART_FlatArrow"
                                      Data="M 0,10 L 15,0 L 15,20 Z"
                                      Fill="{StaticResource FlatBrush}"
                                      Canvas.Left="10"
                                      Canvas.Top="40"
                                      Visibility="Collapsed"/>

                                <!-- Sharp indicator arrow -->
                                <Path x:Name="PART_SharpArrow"
                                      Data="M 15,10 L 0,0 L 0,20 Z"
                                      Fill="{StaticResource SharpBrush}"
                                      Canvas.Top="40"
                                      Visibility="Collapsed"/>

                                <!-- Main indicator -->
                                <Ellipse x:Name="PART_Indicator"
                                         Width="30"
                                         Height="30"
                                         Fill="{StaticResource NeutralBrush}"
                                         Stroke="{StaticResource TextPrimaryBrush}"
                                         StrokeThickness="2"/>
                            </Canvas>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
